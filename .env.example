# Copy to `.env` (or set in PythonAnywhere's WSGI file via os.environ[...] = ...).
# `.env` should NOT be committed.

# Required in production. A long random string. Generate e.g. with:
#   python -c "import secrets; print(secrets.token_hex(32))"
DUPLO_SECRET_KEY=replace-me-with-a-long-random-string

# Database options. Either:
#   (a) Set DUPLO_DATABASE_URI to a full SQLAlchemy URI, OR
#   (b) Set DUPLO_DB_HOST + DUPLO_DB_USER + DUPLO_DB_PASSWORD + DUPLO_DB_NAME
#       (the app will assemble a mysql+pymysql:// URI), OR
#   (c) Leave both unset to use the local SQLite file (sqlite:///duplo.db).

# DUPLO_DATABASE_URI=sqlite:///duplo.db

# DUPLO_DB_HOST=chicotobi.mysql.pythonanywhere-services.com
# DUPLO_DB_USER=chicotobi
# DUPLO_DB_PASSWORD=replace-me
# DUPLO_DB_NAME=chicotobi$duplo
